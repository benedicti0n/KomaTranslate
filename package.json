{
  "name": "manga-translator",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first Chrome extension that translates manga text into English overlays",
  "license": "MIT",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter extension dev",
    "build": "pnpm --filter extension build",
    "zip": "pnpm --filter extension zip",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm --filter extension lint",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/chrome": "^0.0.319",
    "@types/node": "^22.15.21",
    "happy-dom": "^17.4.6",
    "prettier": "^3.6.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
